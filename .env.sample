# GovFunding Chatbot - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git - it's already in .gitignore

# ============================================================================
# Application Environment
# ============================================================================
GOVFUNDING_ENVIRONMENT=development  # development | staging | production

# ============================================================================
# Data Sources
# ============================================================================
GOVFUNDING_NSF_AWARDS_API=https://api.nsf.gov/services/v1/awards.json
GOVFUNDING_NSF_AWARDS_WINDOW_DAYS=7  # Number of days to look back for awards
GOVFUNDING_GRANTS_XML_URL=https://www.grants.gov/extract/latest.zip

# ============================================================================
# Database - Supabase/PostgreSQL (Required for production)
# ============================================================================
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# Find this in: Supabase Dashboard → Settings → Database → Connection String
GOVFUNDING_DATABASE_URL=

# Service role key (for ETL admin operations)
# Find this in: Supabase Dashboard → Settings → API → service_role key (NOT anon key)
GOVFUNDING_SUPABASE_SERVICE_KEY=

# ============================================================================
# Vector Store - Pinecone (Required for RAG/semantic search)
# ============================================================================
GOVFUNDING_PINECONE_API_KEY=
GOVFUNDING_PINECONE_INDEX=my-grants-index
GOVFUNDING_PINECONE_ENVIRONMENT=us-east-1

# ============================================================================
# Local Storage (Development/Backup)
# ============================================================================
GOVFUNDING_LOCAL_DATA_DIR=./data  # Local directory for raw data snapshots
GOVFUNDING_CHROMA_PERSIST_DIR=./chroma_storage  # For local Chroma vector DB (alternative to Pinecone)

# ============================================================================
# Object Storage - S3 (Optional - for production raw data archival)
# ============================================================================
GOVFUNDING_S3_BUCKET=

# ============================================================================
# Logging & Monitoring
# ============================================================================
GOVFUNDING_LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR

# Slack webhook for failure alerts (optional)
GOVFUNDING_SLACK_WEBHOOK_URL=

# ============================================================================
# AI Services (Required for RAG chatbot and embeddings)
# ============================================================================
# OpenAI API key (for embeddings and chat completions)
GOVFUNDING_OPENAI_API_KEY=sk-...

# ============================================================================
# Quick Start (Minimal Setup)
# ============================================================================
# For local testing without Supabase:
#   1. Copy this file to .env
#   2. Keep DATABASE_URL and SUPABASE_SERVICE_KEY empty
#   3. Run: poetry run python -m apps.etl.pipeline
#   4. Check ./data/ folder for JSON outputs
#
# For production with Supabase:
#   1. Create Supabase project at https://app.supabase.com
#   2. Run migrations from infra/migrations/001_initial_schema.sql
#   3. Copy DATABASE_URL and SUPABASE_SERVICE_KEY from dashboard
#   4. Deploy ETL to Render with these environment variables
